<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-tomar">
    <comment>Tomar Note File</comment>
    <comment xml:lang="tr">Tomar Not Dosyası</comment>
    <glob pattern="*.tom"/>
